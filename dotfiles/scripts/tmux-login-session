#!/usr/bin/env bash
set -euo pipefail

if [[ "${1-}" == "--help" ]]; then
	cat <<'EOF'
Usage: tmux-login-session [session-name]

Start tmux from a Bash login shell so Home Manager session variables and
profile setup are loaded before the tmux server starts.

Arguments:
  session-name      Optional tmux session name (default: dev)

Environment:
  TMUX_SOCKET_PATH  Optional non-default tmux socket path
  TMUX_SESSION_NAME Session name to use when no positional argument is given
EOF
	exit 0
fi

script_path="$(cd -- "$(dirname -- "$0")" && pwd)/$(basename -- "$0")"
session_name="${1:-${TMUX_SESSION_NAME:-dev}}"

if [[ -z "${TMUX_LOGIN_SHELL_READY:-}" ]]; then
	export TMUX_LOGIN_SHELL_READY=1
	quoted_script_path=$(printf '%q' "$script_path")
	quoted_session_name=$(printf '%q' "$session_name")
	exec bash -lc "TMUX_LOGIN_SHELL_READY=1 TMUX_SESSION_NAME=${quoted_session_name} ${quoted_script_path} --exec"
fi

if [[ "${1-}" == "--exec" ]]; then
	session_name="${TMUX_SESSION_NAME:-$session_name}"
fi

tmux_args=()
if [[ -n "${TMUX_SOCKET_PATH:-}" ]]; then
	tmux_args=(-S "$TMUX_SOCKET_PATH")
fi

exec tmux "${tmux_args[@]}" new-session -A -s "$session_name"
