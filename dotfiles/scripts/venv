#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.14"
# ///

from __future__ import annotations

import argparse
import os
import shlex
import shutil
import subprocess
import sys
from pathlib import Path


DEFAULT_PYTHON = "3.11"
POETRY_VERSION = "2.1.2"


def run(args: list[str]) -> subprocess.CompletedProcess[str]:
    return subprocess.run(
        args,
        check=False,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
    )


def require(command: str) -> None:
    if shutil.which(command) is None:
        print(f"{command} executable not found.", file=sys.stderr)
        raise SystemExit(1)


def find_project_picker() -> str:
    adjacent = Path(__file__).resolve().with_name("project_picker")
    if adjacent.exists() and os.access(adjacent, os.X_OK):
        return str(adjacent)

    picker = shutil.which("project_picker")
    if picker is not None:
        return picker

    print("project_picker executable not found.", file=sys.stderr)
    raise SystemExit(1)


def shell_join(args: list[str]) -> str:
    return " ".join(shlex.quote(arg) for arg in args)


def emit_activation(target: Path, python: str, uv_args: list[str]) -> None:
    quoted_target = shlex.quote(str(target))
    print(f"cd {quoted_target} || return")
    print("if [ -f .venv/bin/activate ]; then")
    print("  . .venv/bin/activate")
    print("else")
    print(f"  {shell_join(build_uv_venv_command(python, uv_args))} || return")
    print("  if [ -f .venv/bin/activate ]; then")
    print("    . .venv/bin/activate")
    print(f"    {shell_join(['uv', 'pip', 'install', f'poetry=={POETRY_VERSION}'])}")
    print("  else")
    print("    printf '%s\\n' 'Failed to create or activate virtual environment.' >&2")
    print("    return 1")
    print("  fi")
    print("fi")


def build_uv_venv_command(python: str, extra_args: list[str]) -> list[str]:
    return ["uv", "venv", "--python", python, *extra_args]


def parse_args(argv: list[str]) -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Select a repo branch worktree and emit shell commands to activate its venv."
    )
    parser.add_argument("query", nargs="*", help="Initial fzf query for the repo.")
    parser.add_argument(
        "--python",
        default=DEFAULT_PYTHON,
        help=f"Python version for new virtual environments. Defaults to {DEFAULT_PYTHON}.",
    )
    parser.add_argument(
        "--uv-arg",
        action="append",
        default=[],
        metavar="ARG",
        help="Pass an extra argument to `uv venv` without affecting branch selection. Repeat as needed.",
    )
    parser.epilog = (
        "Use `--uv-arg` for arguments that should only go to `uv venv`, "
        "for example: venv feature/foo --python 3.12 --uv-arg=--seed"
    )
    return parser.parse_args(argv)


def main() -> int:
    args = parse_args(sys.argv[1:])
    require("uv")

    picker = find_project_picker()
    proc = run([picker, *args.query])
    if proc.returncode != 0:
        print(proc.stderr, end="", file=sys.stderr)
        return proc.returncode

    target = Path(proc.stdout.strip())

    emit_activation(target, args.python, args.uv_arg)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
