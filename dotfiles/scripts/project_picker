#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.14"
# ///

from __future__ import annotations

import argparse
import shutil
import subprocess
import sys
from dataclasses import dataclass
from pathlib import Path


DEV_ROOT = Path.home() / "dev"
ALL_BRANCH_REFSPEC = "+refs/heads/*:refs/remotes/origin/*"
ALL_TAG_REFSPEC = "+refs/tags/*:refs/tags/*"
BARE_REPO_DIR = "worktree.git"
LEGACY_BARE_REPO_DIR = "bare.git"
RESERVED_WORKTREE_NAMES = {
    BARE_REPO_DIR,
    LEGACY_BARE_REPO_DIR,
    "branches",
    "tags",
    "checkouts",
}


@dataclass(frozen=True)
class WorktreeChoice:
    label: str
    path: Path
    kind: str
    ref: str
    can_create: bool


def sanitize_worktree_name(ref_name: str) -> str:
    return ref_name.strip().replace("/", "-")


def unique_worktree_name(name: str, occupied: set[str], prefix: str) -> str:
    candidate = name
    while candidate in occupied or candidate in RESERVED_WORKTREE_NAMES:
        candidate = f"{prefix}-{candidate}"
    return candidate


def branch_worktree_name(branch: str) -> str:
    name = "trunk" if branch == "master" else sanitize_worktree_name(branch)
    return unique_worktree_name(name, set(), "branch")


def tag_worktree_name(tag: str, branches: list[str]) -> str:
    branch_names = {branch_worktree_name(branch) for branch in branches}
    return unique_worktree_name(sanitize_worktree_name(tag), branch_names, "tag")


def run(
    args: list[str],
    *,
    input_text: str | None = None,
) -> subprocess.CompletedProcess[str]:
    return subprocess.run(
        args,
        input=input_text,
        check=False,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
    )


def require(command: str) -> None:
    if shutil.which(command) is None:
        print(f"{command} executable not found.", file=sys.stderr)
        raise SystemExit(1)


def discover_repos(dev_root: Path) -> list[tuple[str, Path]]:
    if not dev_root.exists():
        print(f"Development directory not found: {dev_root}", file=sys.stderr)
        raise SystemExit(1)

    repos: list[tuple[str, Path]] = []
    seen: set[Path] = set()
    for dirname in (BARE_REPO_DIR, LEGACY_BARE_REPO_DIR):
        for bare_dir in sorted(dev_root.glob(f"*/*/{dirname}")):
            repo_root = bare_dir.parent
            if not repo_root.is_dir() or repo_root in seen:
                continue

            label = str(repo_root.relative_to(dev_root))
            repos.append((label, repo_root))
            seen.add(repo_root)

    return repos


def git_dir_for_repo(repo_root: Path) -> tuple[Path | None, bool]:
    bare_dir = repo_root / BARE_REPO_DIR
    if bare_dir.exists():
        return bare_dir, False

    legacy_bare_dir = repo_root / LEGACY_BARE_REPO_DIR
    if legacy_bare_dir.exists():
        return legacy_bare_dir, True

    return None, False


def find_current_repo_root(
    repos: list[tuple[str, Path]],
    cwd: Path,
) -> Path | None:
    for _, repo_root in repos:
        if cwd == repo_root or cwd.is_relative_to(repo_root):
            return repo_root

    return None


def choose_with_fzf(
    labels: list[str],
    *,
    prompt: str,
    query: str = "",
) -> str | None:
    if not labels:
        return None

    args = ["fzf", "--prompt", prompt]
    if query:
        args += ["--query", query]

    proc = run(args, input_text="\n".join(labels) + "\n")
    if proc.returncode != 0:
        return None

    selected = proc.stdout.strip()
    return selected or None


def list_branch_refs(bare_dir: Path) -> list[str]:
    proc = run(
        [
            "git",
            "--git-dir",
            str(bare_dir),
            "for-each-ref",
            "--format=%(refname:strip=3)",
            "refs/remotes/origin",
        ],
    )
    if proc.returncode != 0:
        return []

    return sorted(
        branch for branch in proc.stdout.splitlines() if branch and branch != "HEAD"
    )


def list_tag_refs(bare_dir: Path) -> list[str]:
    proc = run(
        [
            "git",
            "--git-dir",
            str(bare_dir),
            "for-each-ref",
            "--format=%(refname:strip=2)",
            "refs/tags",
        ],
    )
    if proc.returncode != 0:
        return []

    return sorted(tag for tag in proc.stdout.splitlines() if tag)


def fetch_remote_refs(bare_dir: Path) -> bool:
    proc = run(
        [
            "git",
            "--git-dir",
            str(bare_dir),
            "fetch",
            "--prune",
            "--prune-tags",
            "origin",
            ALL_BRANCH_REFSPEC,
            ALL_TAG_REFSPEC,
        ],
    )
    return proc.returncode == 0


def worktree_label(path: Path, kind: str, ref: str) -> str:
    if kind == "branch":
        return f"{path.name}  [branch: {ref}]"
    if kind == "tag":
        return f"{path.name}  [tag: {ref}]"
    return f"{path.name}  [detached: {ref[:12]}]"


def list_registered_worktrees(bare_dir: Path) -> list[WorktreeChoice]:
    proc = run(
        [
            "git",
            "--git-dir",
            str(bare_dir),
            "worktree",
            "list",
            "--porcelain",
        ],
    )
    if proc.returncode != 0:
        return []

    choices: list[WorktreeChoice] = []
    entry: dict[str, str] = {}

    def append_entry() -> None:
        if "worktree" not in entry:
            return

        path = Path(entry["worktree"])
        if path.name in RESERVED_WORKTREE_NAMES:
            return
        if "branch" in entry:
            branch = entry["branch"].removeprefix("refs/heads/")
            choices.append(
                WorktreeChoice(
                    worktree_label(path, "branch", branch),
                    path,
                    "branch",
                    branch,
                    False,
                )
            )
            return

        head = entry.get("HEAD", "unknown")
        choices.append(
            WorktreeChoice(
                worktree_label(path, "detached", head),
                path,
                "detached",
                head,
                False,
            )
        )

    for line in [*proc.stdout.splitlines(), ""]:
        if not line:
            append_entry()
            entry = {}
            continue
        key, _, value = line.partition(" ")
        entry[key] = value

    return choices


def append_choice(
    choices: list[WorktreeChoice],
    seen_labels: set[str],
    choice: WorktreeChoice,
) -> None:
    if choice.label in seen_labels:
        return
    choices.append(choice)
    seen_labels.add(choice.label)


def list_worktrees(repo_root: Path, *, refresh_empty: bool = False) -> list[WorktreeChoice]:
    choices: list[WorktreeChoice] = []
    seen_labels: set[str] = set()

    bare_dir, legacy = git_dir_for_repo(repo_root)
    if bare_dir is None:
        return choices

    for dirname in (BARE_REPO_DIR, LEGACY_BARE_REPO_DIR):
        registered_git_dir = repo_root / dirname
        if not registered_git_dir.exists():
            continue
        for choice in list_registered_worktrees(registered_git_dir):
            append_choice(choices, seen_labels, choice)

    branch_refs = list_branch_refs(bare_dir)
    tag_refs = list_tag_refs(bare_dir)
    if not legacy and not branch_refs and not tag_refs and refresh_empty:
        fetch_remote_refs(bare_dir)
        branch_refs = list_branch_refs(bare_dir)
        tag_refs = list_tag_refs(bare_dir)

    for branch in branch_refs:
        path = repo_root / branch_worktree_name(branch)
        label = worktree_label(path, "branch", branch)
        if not legacy:
            append_choice(
                choices,
                seen_labels,
                WorktreeChoice(label, path, "branch", branch, True),
            )

    for tag in tag_refs:
        path = repo_root / tag_worktree_name(tag, branch_refs)
        label = worktree_label(path, "tag", tag)
        if not legacy:
            append_choice(
                choices,
                seen_labels,
                WorktreeChoice(label, path, "tag", tag, True),
            )

    branches_root = repo_root / "branches"
    if branches_root.exists():
        for path in sorted(branches_root.rglob("*")):
            if path.is_dir() and (path / ".git").exists():
                raw_label = str(path.relative_to(branches_root))
                branch = "master" if raw_label == "master" else raw_label
                label = worktree_label(path, "branch", branch)
                append_choice(
                    choices,
                    seen_labels,
                    WorktreeChoice(label, path, "branch", branch, False),
                )

    tags_root = repo_root / "tags"
    if tags_root.exists():
        for path in sorted(tags_root.rglob("*")):
            if path.is_dir() and (path / ".git").exists():
                raw_label = str(path.relative_to(tags_root))
                label = worktree_label(path, "tag", raw_label)
                append_choice(
                    choices,
                    seen_labels,
                    WorktreeChoice(label, path, "tag", raw_label, False),
                )

    return choices


def local_branch_exists(bare_dir: Path, branch: str) -> bool:
    proc = run(
        [
            "git",
            "--git-dir",
            str(bare_dir),
            "show-ref",
            "--verify",
            "--quiet",
            f"refs/heads/{branch}",
        ],
    )
    return proc.returncode == 0


def remote_branch_exists(bare_dir: Path, branch: str) -> bool:
    proc = run(
        [
            "git",
            "--git-dir",
            str(bare_dir),
            "show-ref",
            "--verify",
            "--quiet",
            f"refs/remotes/origin/{branch}",
        ],
    )
    return proc.returncode == 0


def resolve_branch_name(bare_dir: Path, branch_label: str) -> str | None:
    candidates = [branch_label]
    if branch_label == "trunk":
        candidates.append("master")
    slash_candidate = branch_label.replace("-", "/")
    if slash_candidate != branch_label:
        candidates.append(slash_candidate)

    for branch in candidates:
        if local_branch_exists(bare_dir, branch) or remote_branch_exists(bare_dir, branch):
            return branch
    return None


def ensure_worktree(repo_root: Path, choice: WorktreeChoice) -> bool:
    target = choice.path
    if (target / ".git").exists():
        return True
    if target.exists():
        return False
    if not choice.can_create:
        return False

    bare_dir = repo_root / BARE_REPO_DIR
    if not bare_dir.exists():
        return False

    target.parent.mkdir(parents=True, exist_ok=True)
    if choice.kind == "branch":
        branch = choice.ref
        add_args = [
            "git",
            "--git-dir",
            str(bare_dir),
            "worktree",
            "add",
            str(target),
        ]
        if local_branch_exists(bare_dir, branch):
            add_args.append(branch)
        else:
            add_args += ["-b", branch, f"origin/{branch}"]
    else:
        add_args = [
            "git",
            "--git-dir",
            str(bare_dir),
            "worktree",
            "add",
            "--detach",
            str(target),
            choice.ref,
        ]

    add_proc = run(add_args)
    if add_proc.returncode != 0:
        print(add_proc.stderr or add_proc.stdout, end="", file=sys.stderr)
        return False

    if choice.kind != "branch":
        return True

    branch = choice.ref
    upstream_proc = run(
        [
            "git",
            "-C",
            str(target),
            "branch",
            "--set-upstream-to",
            f"origin/{branch}",
            branch,
        ],
    )
    if upstream_proc.returncode != 0:
        print(upstream_proc.stderr or upstream_proc.stdout, end="", file=sys.stderr)

    return True


def resolve_worktree_query(
    repos: list[tuple[str, Path]],
    query: str,
    cwd: Path,
) -> Path | None:
    worktree_query = query.strip().strip("/")
    if not worktree_query:
        return None

    def repo_matches(repo_root: Path) -> list[Path]:
        matches: list[Path] = []
        for choice in list_worktrees(repo_root):
            label = choice.label
            aliases = {
                label.strip("/"),
                Path(label).name,
                sanitize_worktree_name(label),
                choice.path.name,
                choice.ref.strip("/"),
                sanitize_worktree_name(choice.ref),
            }
            if worktree_query in aliases and choice.path.exists():
                matches.append(choice.path)
        return matches

    preferred_repo = find_current_repo_root(repos, cwd)
    if preferred_repo is not None:
        matches = repo_matches(preferred_repo)
        if len(matches) == 1:
            return matches[0]

    matches: list[Path] = []
    seen: set[Path] = set()
    for _, repo_root in repos:
        for path in repo_matches(repo_root):
            if path in seen:
                continue
            seen.add(path)
            matches.append(path)

    if len(matches) == 1:
        return matches[0]

    return None


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Select a repo worktree and print its path."
    )
    parser.add_argument("query", nargs="*", help="Initial fzf query for the repo.")
    return parser.parse_args()


def main() -> int:
    args = parse_args()
    require("fzf")
    require("git")

    repos = discover_repos(DEV_ROOT)
    direct_match = resolve_worktree_query(repos, " ".join(args.query), Path.cwd())
    if direct_match is not None:
        print(direct_match)
        return 0

    repo_by_label = dict(repos)
    repo_label = choose_with_fzf(
        list(repo_by_label),
        prompt="Select repo: ",
        query=" ".join(args.query),
    )
    if repo_label is None:
        print("No repository selected.", file=sys.stderr)
        return 1

    repo_root = repo_by_label[repo_label]
    worktrees = list_worktrees(repo_root, refresh_empty=True)
    if not worktrees:
        print(f"No worktrees found for {repo_label}.", file=sys.stderr)
        return 1

    worktree_by_label = {choice.label: choice for choice in worktrees}
    worktree_label = choose_with_fzf(
        list(worktree_by_label),
        prompt="Select worktree: ",
    )
    if worktree_label is None:
        print("No worktree selected.", file=sys.stderr)
        return 1

    choice = worktree_by_label[worktree_label]
    if not ensure_worktree(repo_root, choice):
        print(f"Worktree does not exist: {choice.path}", file=sys.stderr)
        return 1

    print(choice.path)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
