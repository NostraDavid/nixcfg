#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.14"
# ///

from __future__ import annotations

import argparse
import shutil
import subprocess
import sys
from pathlib import Path


DEV_ROOT = Path.home() / "dev"
ALL_BRANCH_REFSPEC = "+refs/heads/*:refs/remotes/origin/*"


def sanitize_worktree_name(ref_name: str) -> str:
    return ref_name.strip().replace("/", "-")


def run(
    args: list[str],
    *,
    input_text: str | None = None,
) -> subprocess.CompletedProcess[str]:
    return subprocess.run(
        args,
        input=input_text,
        check=False,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
    )


def require(command: str) -> None:
    if shutil.which(command) is None:
        print(f"{command} executable not found.", file=sys.stderr)
        raise SystemExit(1)


def discover_repos(dev_root: Path) -> list[tuple[str, Path]]:
    if not dev_root.exists():
        print(f"Development directory not found: {dev_root}", file=sys.stderr)
        raise SystemExit(1)

    repos: list[tuple[str, Path]] = []
    for bare_dir in sorted(dev_root.glob("*/*/bare.git")):
        repo_root = bare_dir.parent
        if not repo_root.is_dir():
            continue

        label = str(repo_root.relative_to(dev_root))
        repos.append((label, repo_root))

    return repos


def find_current_repo_root(
    repos: list[tuple[str, Path]],
    cwd: Path,
) -> Path | None:
    for _, repo_root in repos:
        if cwd == repo_root or cwd.is_relative_to(repo_root):
            return repo_root

    return None


def choose_with_fzf(
    labels: list[str],
    *,
    prompt: str,
    query: str = "",
) -> str | None:
    if not labels:
        return None

    args = ["fzf", "--prompt", prompt]
    if query:
        args += ["--query", query]

    proc = run(args, input_text="\n".join(labels) + "\n")
    if proc.returncode != 0:
        return None

    selected = proc.stdout.strip()
    return selected or None


def list_git_refs(bare_dir: Path) -> list[str]:
    proc = run(
        [
            "git",
            "--git-dir",
            str(bare_dir),
            "for-each-ref",
            "--format=%(refname:strip=3)",
            "refs/remotes/origin",
        ],
    )
    if proc.returncode != 0:
        return []

    return sorted(
        branch for branch in proc.stdout.splitlines() if branch and branch != "HEAD"
    )


def fetch_remote_refs(bare_dir: Path) -> bool:
    proc = run(
        [
            "git",
            "--git-dir",
            str(bare_dir),
            "fetch",
            "--prune",
            "origin",
            ALL_BRANCH_REFSPEC,
        ],
    )
    return proc.returncode == 0


def list_branches(repo_root: Path, *, refresh_empty: bool = False) -> list[tuple[str, Path]]:
    branches_root = repo_root / "branches"
    branches: list[tuple[str, Path]] = []

    if branches_root.exists():
        for path in sorted(branches_root.rglob("*")):
            if path.is_dir() and (path / ".git").exists():
                label = str(path.relative_to(branches_root))
                branches.append((label, path))

    bare_dir = repo_root / "bare.git"
    if bare_dir.exists():
        remote_branches = list_git_refs(bare_dir)
        if not remote_branches and refresh_empty:
            fetch_remote_refs(bare_dir)
            remote_branches = list_git_refs(bare_dir)

        existing_labels = {label for label, _ in branches}
        for branch in remote_branches:
            label = sanitize_worktree_name(branch)
            if label in existing_labels:
                continue
            branches.append((label, branches_root / label))

    return branches


def local_branch_exists(bare_dir: Path, branch: str) -> bool:
    proc = run(
        [
            "git",
            "--git-dir",
            str(bare_dir),
            "show-ref",
            "--verify",
            "--quiet",
            f"refs/heads/{branch}",
        ],
    )
    return proc.returncode == 0


def remote_branch_exists(bare_dir: Path, branch: str) -> bool:
    proc = run(
        [
            "git",
            "--git-dir",
            str(bare_dir),
            "show-ref",
            "--verify",
            "--quiet",
            f"refs/remotes/origin/{branch}",
        ],
    )
    return proc.returncode == 0


def resolve_branch_name(bare_dir: Path, branch_label: str) -> str | None:
    candidates = [branch_label]
    slash_candidate = branch_label.replace("-", "/")
    if slash_candidate != branch_label:
        candidates.append(slash_candidate)

    for branch in candidates:
        if local_branch_exists(bare_dir, branch) or remote_branch_exists(bare_dir, branch):
            return branch
    return None


def ensure_branch_worktree(repo_root: Path, branch_label: str, target: Path) -> bool:
    if (target / ".git").exists():
        return True
    if target.exists():
        return False

    bare_dir = repo_root / "bare.git"
    if not bare_dir.exists():
        return False

    branch = resolve_branch_name(bare_dir, branch_label)
    if branch is None:
        return False

    target.parent.mkdir(parents=True, exist_ok=True)
    add_args = [
        "git",
        "--git-dir",
        str(bare_dir),
        "worktree",
        "add",
        str(target),
    ]
    if local_branch_exists(bare_dir, branch):
        add_args.append(branch)
    else:
        add_args += ["-b", branch, f"origin/{branch}"]

    add_proc = run(add_args)
    if add_proc.returncode != 0:
        print(add_proc.stderr or add_proc.stdout, end="", file=sys.stderr)
        return False

    upstream_proc = run(
        [
            "git",
            "-C",
            str(target),
            "branch",
            "--set-upstream-to",
            f"origin/{branch}",
            branch,
        ],
    )
    if upstream_proc.returncode != 0:
        print(upstream_proc.stderr or upstream_proc.stdout, end="", file=sys.stderr)

    return True


def resolve_branch_query(
    repos: list[tuple[str, Path]],
    query: str,
    cwd: Path,
) -> Path | None:
    branch_query = query.strip().strip("/")
    if not branch_query:
        return None

    def repo_matches(repo_root: Path) -> list[Path]:
        matches: list[Path] = []
        for label, path in list_branches(repo_root):
            aliases = {
                label.strip("/"),
                Path(label).name,
                sanitize_worktree_name(label),
            }
            if branch_query in aliases and path.exists():
                matches.append(path)
        return matches

    preferred_repo = find_current_repo_root(repos, cwd)
    if preferred_repo is not None:
        matches = repo_matches(preferred_repo)
        if len(matches) == 1:
            return matches[0]

    matches: list[Path] = []
    seen: set[Path] = set()
    for _, repo_root in repos:
        for path in repo_matches(repo_root):
            if path in seen:
                continue
            seen.add(path)
            matches.append(path)

    if len(matches) == 1:
        return matches[0]

    return None


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Select a repo branch worktree and print its path."
    )
    parser.add_argument("query", nargs="*", help="Initial fzf query for the repo.")
    return parser.parse_args()


def main() -> int:
    args = parse_args()
    require("fzf")
    require("git")

    repos = discover_repos(DEV_ROOT)
    direct_match = resolve_branch_query(repos, " ".join(args.query), Path.cwd())
    if direct_match is not None:
        print(direct_match)
        return 0

    repo_by_label = dict(repos)
    repo_label = choose_with_fzf(
        list(repo_by_label),
        prompt="Select repo: ",
        query=" ".join(args.query),
    )
    if repo_label is None:
        print("No repository selected.", file=sys.stderr)
        return 1

    repo_root = repo_by_label[repo_label]
    branches = list_branches(repo_root, refresh_empty=True)
    if not branches:
        print(f"No branches found for {repo_label}.", file=sys.stderr)
        return 1

    branch_by_label = dict(branches)
    branch_label = choose_with_fzf(
        list(branch_by_label),
        prompt="Select branch: ",
    )
    if branch_label is None:
        print("No branch selected.", file=sys.stderr)
        return 1

    target = branch_by_label[branch_label]
    if not ensure_branch_worktree(repo_root, branch_label, target):
        print(f"Branch worktree does not exist: {target}", file=sys.stderr)
        return 1

    print(target)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
