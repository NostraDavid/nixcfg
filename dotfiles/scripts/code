#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.14"
# ///

from __future__ import annotations

import argparse
import os
import shutil
import subprocess
import sys
from pathlib import Path


def run(args: list[str]) -> subprocess.CompletedProcess[str]:
    return subprocess.run(
        args,
        check=False,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
    )


def require(command: str) -> None:
    if shutil.which(command) is None:
        print(f"{command} executable not found.", file=sys.stderr)
        raise SystemExit(1)


def find_code_binary() -> str:
    own_path = Path(__file__).resolve()
    for path_dir in os.environ.get("PATH", "").split(os.pathsep):
        if not path_dir:
            continue

        candidate = Path(path_dir) / "code"
        if not candidate.exists() or not os.access(candidate, os.X_OK):
            continue
        if candidate.resolve() == own_path:
            continue
        return str(candidate)

    print("VS Code code executable not found.", file=sys.stderr)
    raise SystemExit(1)


def find_project_picker() -> str:
    adjacent = Path(__file__).resolve().with_name("project_picker")
    if adjacent.exists() and os.access(adjacent, os.X_OK):
        return str(adjacent)

    picker = shutil.which("project_picker")
    if picker is not None:
        return picker

    print("project_picker executable not found.", file=sys.stderr)
    raise SystemExit(1)


def clean_vscode_env() -> dict[str, str]:
    env = os.environ.copy()
    for name in (
        "VSCODE_IPC_HOOK_CLI",
        "ELECTRON_RUN_AS_NODE",
        "NIX_CONFIG",
        "IN_NIX_SHELL",
        "shellHook",
        "stdenv",
        "out",
        "buildInputs",
        "nativeBuildInputs",
        "builder",
        "phases",
    ):
        env.pop(name, None)
    return env


def supports_flag(code_bin: str, flag: str) -> bool:
    proc = run([code_bin, "--help"])
    if proc.returncode != 0:
        return False

    help_text = f"{proc.stdout}\n{proc.stderr}"
    return flag in help_text


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Open a repo worktree in VS Code."
    )
    parser.add_argument("query", nargs="*", help="Initial fzf query for the repo.")
    return parser.parse_args()


def main() -> int:
    args = parse_args()
    code_bin = find_code_binary()
    env = clean_vscode_env()
    picker = find_project_picker()
    proc = run([picker, *args.query])
    if proc.returncode != 0:
        print(proc.stderr, end="", file=sys.stderr)
        return proc.returncode

    target = Path(proc.stdout.strip())
    command = [code_bin, str(target)]

    if supports_flag(code_bin, "--new-window"):
        command.insert(1, "--new-window")

    return subprocess.run(
        command,
        env=env,
        check=False,
    ).returncode


if __name__ == "__main__":
    raise SystemExit(main())
