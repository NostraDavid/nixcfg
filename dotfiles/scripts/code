#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.14"
# ///

from __future__ import annotations

import argparse
import json
import os
import shutil
import subprocess
import sys
from pathlib import Path

WINDOW_FLAGS = {"--new-window", "--reuse-window", "--add", "-r"}


def run(args: list[str]) -> subprocess.CompletedProcess[str]:
    return subprocess.run(
        args,
        check=False,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
    )


def require(command: str) -> None:
    if shutil.which(command) is None:
        print(f"{command} executable not found.", file=sys.stderr)
        raise SystemExit(1)


def find_code_binary() -> str:
    own_path = Path(__file__).resolve()
    for path_dir in os.environ.get("PATH", "").split(os.pathsep):
        if not path_dir:
            continue

        candidate = Path(path_dir) / "code"
        if not candidate.exists() or not os.access(candidate, os.X_OK):
            continue
        if candidate.resolve() == own_path:
            continue
        return str(candidate)

    print("VS Code code executable not found.", file=sys.stderr)
    raise SystemExit(1)


def find_project_picker() -> str:
    adjacent = Path(__file__).resolve().with_name("project_picker")
    if adjacent.exists() and os.access(adjacent, os.X_OK):
        return str(adjacent)

    picker = shutil.which("project_picker")
    if picker is not None:
        return picker

    print("project_picker executable not found.", file=sys.stderr)
    raise SystemExit(1)


def clean_vscode_env() -> dict[str, str]:
    env = os.environ.copy()
    for name in (
        "VSCODE_IPC_HOOK_CLI",
        "ELECTRON_RUN_AS_NODE",
        "VIRTUAL_ENV",
        "UV_RUN_RECURSION_DEPTH",
        "NIX_CONFIG",
        "IN_NIX_SHELL",
        "shellHook",
        "stdenv",
        "out",
        "buildInputs",
        "nativeBuildInputs",
        "builder",
        "phases",
    ):
        env.pop(name, None)
    return env


def supports_flag(code_bin: str, flag: str) -> bool:
    proc = run([code_bin, "--help"])
    if proc.returncode != 0:
        return False

    help_text = f"{proc.stdout}\n{proc.stderr}"
    return flag in help_text


def is_path_argument(arg: str) -> bool:
    if not arg or arg.startswith("-"):
        return False

    path = Path(arg).expanduser()
    return (
        path.exists()
        or arg in {".", "..", "~"}
        or arg.startswith(("./", "../", "~/", "/"))
        or "/" in arg
    )


def normalize_code_arg(arg: str) -> str:
    if not is_path_argument(arg):
        return arg

    return str(Path(arg).expanduser().resolve(strict=False))


def resolve_direct_code_args(args: list[str]) -> list[str] | None:
    if not args:
        return None

    if any(arg.startswith("-") or is_path_argument(arg) for arg in args):
        return [normalize_code_arg(arg) for arg in args]

    return None


def add_new_window_flag(
    code_bin: str,
    command: list[str],
    *,
    skip_when_flags_present: bool = False,
) -> list[str]:
    if skip_when_flags_present and any(arg.startswith("-") for arg in command[1:]):
        return command

    if not supports_flag(code_bin, "--new-window"):
        return command

    if any(arg in WINDOW_FLAGS for arg in command[1:]):
        return command

    return [command[0], "--new-window", *command[1:]]

def ensure_vscode_settings(target: Path) -> None:
    """Ensure .vscode/settings.json exists with window.title set to the project name.

    The project name is the parent folder name (e.g. for ~/dev/org/repo/trunk,
    the project name is "repo").
    """
    vscode_dir = target / ".vscode"
    settings_file = vscode_dir / "settings.json"
    project_name = target.parent.name

    if not settings_file.exists():
        vscode_dir.mkdir(parents=True, exist_ok=True)
        settings_file.write_text(
            json.dumps({"window.title": project_name}, indent=2, sort_keys=True) + "\n"
        )
        return

    try:
        settings = json.loads(settings_file.read_text())
    except (json.JSONDecodeError, OSError):
        return

    if settings.get("window.title") != project_name:
        settings["window.title"] = project_name
        settings_file.write_text(json.dumps(settings, indent=2, sort_keys=True) + "\n")


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Open a repo worktree in VS Code.")
    parser.add_argument("query", nargs="*", help="Initial fzf query for the repo.")
    return parser.parse_args()


def main() -> int:
    args = parse_args()
    code_bin = find_code_binary()
    env = clean_vscode_env()

    if not args.query:
        return subprocess.run(
            [code_bin],
            env=env,
            check=False,
        ).returncode

    direct_args = resolve_direct_code_args(args.query)
    if direct_args is not None:
        command = add_new_window_flag(
            code_bin,
            [code_bin, *direct_args],
            skip_when_flags_present=True,
        )
        return subprocess.run(
            command,
            env=env,
            check=False,
        ).returncode

    picker = find_project_picker()
    proc = run([picker, *args.query])
    if proc.returncode != 0:
        print(proc.stderr, end="", file=sys.stderr)
        return proc.returncode

    target = Path(proc.stdout.strip())
    ensure_vscode_settings(target)
    command = add_new_window_flag(code_bin, [code_bin, str(target)])

    return subprocess.run(
        command,
        env=env,
        check=False,
    ).returncode


if __name__ == "__main__":
    raise SystemExit(main())
