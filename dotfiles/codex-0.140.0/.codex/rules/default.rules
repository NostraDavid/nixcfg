prefix_rule(pattern=["ip", "addr", "show", "wg0"], decision="allow")
prefix_rule(pattern=["sudo", "wg", "show"], decision="allow")
prefix_rule(pattern=["nix", "build", ".#nixosConfigurations.frigg.config.system.build.toplevel", "--dry-run"], decision="allow")
prefix_rule(pattern=["nix", "store", "prefetch-file"], decision="allow")
prefix_rule(pattern=["just", "infra-up"], decision="allow")
prefix_rule(pattern=["podman", "ps"], decision="allow")
prefix_rule(pattern=["podman-compose", "-f", "compose.yml", "logs"], decision="allow")
prefix_rule(pattern=["just", "infra-reset"], decision="allow")
prefix_rule(pattern=["podman", "volume", "ls"], decision="allow")
prefix_rule(pattern=["podman", "volume", "inspect"], decision="allow")
prefix_rule(pattern=["podman", "inspect"], decision="allow")
prefix_rule(pattern=["podman", "rm", "-f"], decision="allow")
prefix_rule(pattern=["podman", "compose", "-f", "docker-compose.yml", "up", "-d"], decision="allow")
prefix_rule(pattern=["podman", "compose", "-f", "docker-compose.yml", "logs"], decision="allow")
prefix_rule(pattern=["xinput"], decision="allow")
