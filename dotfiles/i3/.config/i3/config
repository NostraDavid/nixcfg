font pango:monospace 8

floating_modifier Mod4
focus_wrapping yes
focus_follows_mouse yes
focus_on_window_activation smart
mouse_warping output
workspace_layout default
workspace_auto_back_and_forth no

bindsym Mod1+F4 kill
bindsym Mod1+Print exec --no-startup-id spectacle --new-instance --activewindow
bindsym Mod4+0 workspace number 10
bindsym Mod4+1 workspace number 1
bindsym Mod4+2 workspace number 2
bindsym Mod4+3 workspace number 3
bindsym Mod4+4 workspace number 4
bindsym Mod4+5 workspace number 5
bindsym Mod4+6 workspace number 6
bindsym Mod4+7 workspace number 7
bindsym Mod4+8 workspace number 8
bindsym Mod4+9 workspace number 9
bindsym Mod4+Down focus down
bindsym Mod4+Left focus left
bindsym Mod4+Page_Down move scratchpad
bindsym Mod4+Page_Up fullscreen toggle
bindsym Mod4+Return exec ghostty
bindsym Mod4+Right focus right
bindsym Mod4+Shift+0 move container to workspace number 10
bindsym Mod4+Shift+1 move container to workspace number 1
bindsym Mod4+Shift+2 move container to workspace number 2
bindsym Mod4+Shift+3 move container to workspace number 3
bindsym Mod4+Shift+4 move container to workspace number 4
bindsym Mod4+Shift+5 move container to workspace number 5
bindsym Mod4+Shift+6 move container to workspace number 6
bindsym Mod4+Shift+7 move container to workspace number 7
bindsym Mod4+Shift+8 move container to workspace number 8
bindsym Mod4+Shift+9 move container to workspace number 9
bindsym Mod4+Shift+Down move down
bindsym Mod4+Shift+Left move left
bindsym Mod4+Shift+Page_Down scratchpad show
bindsym Mod4+Shift+Right move right
bindsym Mod4+Shift+Tab focus prev
bindsym Mod4+Shift+Up move up
bindsym Mod4+Shift+c reload
bindsym Mod4+Shift+d exec --no-startup-id i3-show-desktop
bindsym Mod4+Shift+e exec i3-nagbar -t warning -m 'Do you want to exit i3?' -b 'Yes' 'i3-msg exit'
bindsym Mod4+Shift+f floating toggle
bindsym Mod4+Shift+l exec --no-startup-id i3lock -c 111111
bindsym Mod4+Shift+minus move scratchpad
bindsym Mod4+Shift+q kill
bindsym Mod4+Shift+r restart
bindsym Mod4+Tab focus next
bindsym Mod4+Up focus up
bindsym Mod4+a exec --no-startup-id pavucontrol
bindsym Mod4+d exec --no-startup-id dmenu_run -i
bindsym Mod4+e exec --no-startup-id dolphin
bindsym Mod4+f fullscreen toggle
bindsym Mod4+h split h
bindsym Mod4+minus scratchpad show
bindsym Mod4+r mode resize
bindsym Mod4+s layout stacking
bindsym Mod4+v split v
bindsym Mod4+w layout tabbed
bindsym Print exec --no-startup-id spectacle --new-instance
bindsym Shift+Print exec --no-startup-id spectacle --new-instance --region
bindsym XF86AudioLowerVolume exec --no-startup-id wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
bindsym XF86AudioMute exec --no-startup-id wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
bindsym XF86AudioRaiseVolume exec --no-startup-id wpctl set-volume -l 1 @DEFAULT_AUDIO_SINK@ 5%+
bindsym XF86MonBrightnessDown exec --no-startup-id brightnessctl set 5%-
bindsym XF86MonBrightnessUp exec --no-startup-id brightnessctl set +5%

mode "resize" {
  bindsym Down resize grow height 10 px or 10 ppt
  bindsym Escape mode default
  bindsym Left resize shrink width 10 px or 10 ppt
  bindsym Return mode default
  bindsym Right resize grow width 10 px or 10 ppt
  bindsym Up resize shrink height 10 px or 10 ppt
}

bar {
  status_command i3status
}

exec --no-startup-id nm-applet
exec --no-startup-id i3-msg 'workspace 1'
