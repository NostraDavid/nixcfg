#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.14"
# ///

from __future__ import annotations

import re
import sys
from pathlib import Path
from textwrap import dedent

SPECIAL_PREFIXES = (
    "Merge ",
    "Revert ",
    "fixup! ",
    "squash! ",
    "amend! ",
)

CONVENTIONAL_PREFIXES = re.compile(
    r"^(build|chore|ci|docs|feat|fix|perf|refactor|revert|style|test)"
    r"(\([^)]+\))?!?: "
)

SCOPED_COMMIT = re.compile(
    r"^[a-zA-Z0-9*][a-zA-Z0-9._/-]*( \([A-Z][A-Z0-9]+-[0-9]+\))?: \S.*"
)


def subject_from(message_file: Path) -> str:
    for line in message_file.read_text(encoding="utf-8").splitlines():
        stripped = line.strip()
        if not stripped or stripped.startswith("#"):
            continue
        return line
    return ""


def reject(message: str) -> int:
    print(message, file=sys.stderr)
    return 1


def main(argv: list[str]) -> int:
    if len(argv) != 2:
        return reject("usage: commit-msg <message-file>")

    subject = subject_from(Path(argv[1]))
    if not subject:
        return reject("empty commit message")

    if subject.startswith(SPECIAL_PREFIXES):
        return 0

    if CONVENTIONAL_PREFIXES.match(subject):
        return reject(
            dedent(
                """\
                Invalid commit message: Conventional Commits are not used here.

                Use Scoped Commits instead:
                  <scope>: <description>

                Examples:
                  git: add scoped commit hook
                  pkgs/codex: update wrapper"""
            )
        )

    if not SCOPED_COMMIT.match(subject):
        return reject(
            dedent(
                f"""\
                Invalid commit message: expected a Scoped Commit subject.

                Subject:
                  {subject}

                Use:
                  <scope>: <description>

                Examples:
                  git: add scoped commit hook
                  pkgs/codex: update wrapper
                  *.nix: normalize attrsets

                Rules:
                  - scope may start with *; other letters must be lowercase
                  - description must not be empty
                  - Conventional Commits such as "feat:" and "fix:" are rejected"""
            )
        )

    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv))
