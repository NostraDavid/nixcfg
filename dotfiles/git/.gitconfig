[user]
	name = NostraDavid
	email = 55331731+NostraDavid@users.noreply.github.com

[init]
	defaultBranch = master
	templatedir = ~/.git-templates

[core]
	excludesfile = ~/.config/git/ignore
	hooksPath = ~/.config/git/hooks
	whitespace = -indent-with-non-tab,trailing-space,cr-at-eol,space-before-tab
	fsmonitor = true
	untrackedCache = true

[column]
	ui = auto

[branch]
	# Also set upstream when a new local branch is created from another local
	# branch. Some tools do that instead of branching directly from
	# origin/<name>, which otherwise leaves `git pull` and `git push` without
	# tracking info.
	autoSetupMerge = always
	sort = -committerdate

[tag]
	sort = version:refname

[help]
	autocorrect = prompt

[credential]
	helper = store

[gpg]
	format = ssh

[log]
	date = iso

[pager]
	branch = false
	diff = delta
	show = delta
	log = delta
  difftool = true

[delta]
	navigate = true
	light = false
	line-numbers = true
	side-by-side = true

[fetch]
	all = true
	prune = true
	pruneTags = true
	fsckObjects = true

[worktree]
	guessRemote = true

[pull]
	# run this, if you want to skip rebase: `git pull --no-rebase`
	rebase = true

[push]
	default = current
	autoSetupRemote = true
	followTags = true

[commit]
	template = ~/.config/git/commit-template
	verbose = true

[rebase]
	autoSquash = true
	autoStash = true
	updateRefs = true

[checkout]
	defaultRemote = origin
	guess = true

[merge]
	ff = true
	conflictStyle = zdiff3
	tool = nvimdiff

[merge "mergiraf"]
	name = mergiraf
	driver = mergiraf merge --git %O %A %B -s %S -x %X -y %Y -p %P -l %L

[rerere]
	# "reuse recorded resolution" should help me with an improved rebase
	enabled = true
	autoupdate = true
	gc = 30

[apply]
	whitespace = fix

[diff]
	algorithm = histogram
	colorMoved = plain
	external = difft
	mnemonicPrefix = true
	renames = true
	tool = difftastic

[difftool]
	prompt = false

[difftool "difftastic"]
  cmd = difft "$MERGED" "$LOCAL" "abcdef1" "100644" "$REMOTE" "abcdef2" "100644"

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true

[transfer]
	fsckObjects = true

[receive]
	fsckObjects = true

[alias]
	# Basic commands
	st = status
	br = branch
	co = "!f() { \
	  branch=$(git for-each-ref 'refs/heads/' 'refs/remotes/origin/' --format='%(refname:short)' \
	    | sed 's#^origin/##' \
	    | grep -v '^HEAD$' \
	    | sort -u \
	    | fzf --query=\"$1\" --select-1); \
	  [ -n \"$branch\" ] || exit 0; \
	  git switch \"$branch\" 2>/dev/null || git switch -c \"$branch\" --track origin/\"$branch\"; \
	}; f"
	ci = commit -v
	cam = commit -am
	df = diff
	sa = stash
	mt = mergetool
	cp = cherry-pick
	undo = reset HEAD~1 --mixed

	# Worktree workflow
	wt = worktree
	wtl = worktree list
	wta = "!f() { \
	b=\"$1\"; \
	[ -n \"$b\" ] || { echo \"usage: git wta <branch> [path]\" >&2; exit 1; }; \
	p=\"${2:-../.worktrees/$b}\"; \
	git worktree add \"$p\" \"$b\"; \
	}; f"
	wtr = worktree remove
	wtrf = worktree remove --force
	wtp = worktree prune
	wtinit = "!f() { \
	url=\"$1\"; \
	dir=\"$2\"; \
	main_branch=\"${3:-master}\"; \
	[ -n \"$url\" ] || { echo \"usage: git wtinit <repo-url> [target-dir] [main-branch]\" >&2; exit 1; }; \
	if [ -z \"$dir\" ]; then dir=\"$(basename \"${url%.git}\")\"; fi; \
	mkdir -p \"$dir\" && cd \"$dir\" || exit 1; \
	[ ! -e worktree.git ] || { echo \"worktree.git already exists in $PWD\" >&2; exit 1; }; \
	git clone --bare \"$url\" worktree.git || exit 1; \
	git -C worktree.git config remote.origin.fetch '+refs/heads/*:refs/remotes/origin/*'; \
	git -C worktree.git config --add remote.origin.fetch '+refs/tags/*:refs/tags/*'; \
	git -C worktree.git fetch origin '+refs/heads/*:refs/remotes/origin/*' '+refs/tags/*:refs/tags/*' || exit 1; \
	git --git-dir worktree.git worktree add -b \"$main_branch\" trunk \"origin/$main_branch\" 2>/dev/null || git --git-dir worktree.git worktree add trunk \"$main_branch\" || exit 1; \
	git -C trunk branch --set-upstream-to \"origin/$main_branch\" \"$main_branch\" 2>/dev/null || true; \
	echo \"Initialized worktree repo at $PWD (trunk: $main_branch)\"; \
	}; f"

	# Pull, push, and fetch workflow
	fe = fetch --all --prune
	pl = pull --rebase
	pulltags = fetch origin +refs/tags/*:refs/tags/*
	tagsync = "!f(){ git fetch \"${1:-origin}\" +refs/tags/*:refs/tags/*; }; f"
	fpush = "!f() { \
	branch=$(git rev-parse --abbrev-ref HEAD); \
	git push --force-with-lease origin \"$branch\"; \
	}; f"
	yeet = "!f() { git add -A && git commit -m \"$*\" && git push; }; f"

	# Log and diff views
	lg = log --color --graph --abbrev-commit --pretty=format:'%Cred%h %C(bold blue)%an%Creset %Cgreen%ad -%C(yellow)%d%Creset %s' --date=format:'%Y-%m-%d %H:%M'
	cached = diff --cached --no-ext-diff
	rawdiff = !git --no-pager -c diff.external= -c pager.diff=false diff --no-ext-diff --no-color
	ddiff = -c diff.external=difft diff
	dlog = -c diff.external=difft log --ext-diff
	dshow = -c diff.external=difft show --ext-diff

	# Repository analytics
	hotspots = "!f() { since=\"${1:-1 year ago}\"; limit=\"${2:-20}\"; git log --format=format: --name-only --since=\"$since\" | sed '/^$/d' | sort | uniq -c | sort -nr | head -n \"$limit\"; }; f"
	authors = "!f() { if [ -n \"$1\" ]; then git shortlog -sn --no-merges --since=\"$1\"; else git shortlog -sn --no-merges; fi; }; f"
	bugspots = "!f() { since=\"${1:-}\"; limit=\"${2:-20}\"; if [ -n \"$since\" ]; then git log -i -E --grep='fix|bug|broken' --since=\"$since\" --name-only --format=''; else git log -i -E --grep='fix|bug|broken' --name-only --format=''; fi | sed '/^$/d' | sort | uniq -c | sort -nr | head -n \"$limit\"; }; f"
	velocity = "!git log --format='%ad' --date=format:'%Y-%m' | sort | uniq -c"
	firefights = "!f() { since=\"${1:-1 year ago}\"; git log --oneline --since=\"$since\" | grep -iE 'revert|hotfix|emergency|rollback' || true; }; f"

	# First-parent commit walking
	walk = "!f() { b=\"$1\"; [ -n \"$b\" ] || { echo \"usage: git walk <branch>\" >&2; exit 1; }; git rev-parse --verify \"$b\" >/dev/null 2>&1 || { echo \"unknown branch: $b\" >&2; exit 1; }; git config --global walk.branch \"$b\"; git switch --detach \"$b\"; }; f"
	prev = "!f() { b=\"$(git config --global --get walk.branch)\" || { echo \"no walk.branch set; use: git walk <branch>\" >&2; exit 1; }; h=\"$(git rev-parse HEAD)\"; t=\"$(git rev-list --first-parent --reverse \"$b\" | awk -v h=\"$h\" 'BEGIN { prev=\"\" } $0 == h { if (prev != \"\") print prev; found=1; exit } { prev=$0 } END { if (!found) exit 2 }')\"; rc=$?; [ $rc -ne 2 ] || { echo \"HEAD is not on the first-parent line of $b\" >&2; exit 1; }; [ -n \"$t\" ] || { echo \"already at oldest commit on $b\" >&2; exit 1; }; git switch --detach \"$t\"; }; f"
	next = "!f() { b=\"$(git config --global --get walk.branch)\" || { echo \"no walk.branch set; use: git walk <branch>\" >&2; exit 1; }; h=\"$(git rev-parse HEAD)\"; t=\"$(git rev-list --first-parent --reverse \"$b\" | awk -v h=\"$h\" 'found { print; exit } $0 == h { found=1 } END { if (!found) exit 2 }')\"; rc=$?; [ $rc -ne 2 ] || { echo \"HEAD is not on the first-parent line of $b\" >&2; exit 1; }; [ -n \"$t\" ] || { echo \"already at newest commit on $b\" >&2; exit 1; }; git switch --detach \"$t\"; }; f"
